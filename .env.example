# Optional overrides — a working .env is auto-created on first run (npm run setup).
# Normal installs use Docker Postgres; you should not need to edit DATABASE_URL.
#
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/next?schema=public"
#
# Advanced only — external Postgres (not supported for normal installs):
# NEXT_MANAGE_POSTGRES=false
# DATABASE_URL="postgresql://user:pass@host:5432/next?schema=public"
#
# Optional: override the auto-generated local encryption key file (.local/encryption.key)
# APP_ENCRYPTION_KEY=""  # 32 bytes, base64 — run: openssl rand -base64 32
#
# Legacy env fallbacks (optional). Settings in the app UI override these values.
# WEBEX_CLIENT_ID=""
# WEBEX_CLIENT_SECRET=""
