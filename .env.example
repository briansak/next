# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/next?schema=public"

# Auth (generate with: openssl rand -base64 32)
SESSION_SECRET="change-me"

# Seed — initial user (used by npm run db:seed)
SEED_PARTNER_NAME="Acme Corp"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="changeme123"
SEED_ADMIN_NAME="Admin"

# Webex Integration (https://developer.webex.com)
WEBEX_CLIENT_ID=""
WEBEX_CLIENT_SECRET=""
WEBEX_REDIRECT_URI="http://localhost:3000/api/integrations/webex/callback"
# Scope preset: standard | standard+meetings | compliance | standard+webhooks | compliance+webhooks
# - standard: spark:messages_read spark:rooms_read (user's spaces)
# - standard+meetings: adds meeting:* scopes + spark:people_read for /people/me
# - standard+meetings+vidcast: adds Vidcast MCP scopes (spark:mcp, Identity:*)
# - compliance: org-wide read via spark-compliance:* (admin/compliance role)
WEBEX_SCOPE_MODE="standard+meetings+vidcast"
# Vidcast MCP endpoint override (optional):
# WEBEX_MCP_URL="https://mcp.webexapis.com/mcp/vidcast"
# Internal Webex APIs MCP (VPN, no Vidcast tools): WEBEX_MCP_URL="https://aicoding-mcp-webexapis.cisco.com/mcp/"
# Or set explicit scopes (must match what's checked on your integration):
# WEBEX_SCOPES="spark-compliance:messages_read spark-compliance:rooms_read"
# HMAC secret for webhook signature verification (generate with: openssl rand -hex 32)
WEBEX_WEBHOOK_SECRET=""

# Optional: local Ollama for enhanced summaries
# These can also be configured in Settings → Preferences → App configuration.
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.1:8b"
# Optional: Ollama summaries for Webex meeting transcripts during sync (default: heuristic)
# ENABLE_MEETING_OLLAMA_SUMMARY="true"
# OLLAMA_MEETING_TIMEOUT_MS="120000"
# Optional: faster model for /technologies space summaries (recommended if llama3.1:8b is slow)
# OLLAMA_TECHNOLOGY_MODEL="llama3.2:3b"
# Optional: vision model for call replay highlights (scripts/summarize-call-vision.ts)
# OLLAMA_VISION_MODEL="qwen2.5vl:7b"
# OLLAMA_TEXT_MODEL="llama3.2:3b"
# Optional: partner ask SLA window in hours (default 48). Also configurable in App configuration.
# PARTNER_ASK_SLA_HOURS="48"

# Optional: transcribe Webex recordings when Webex transcripts are unavailable
# Setup: python3 -m venv .venv && .venv/bin/pip install -r requirements.txt
ENABLE_RECORDING_TRANSCRIPTION="false"
WHISPER_BIN=".venv/bin/whisper"
WHISPER_MODEL="tiny"

# Optional: import Outlook .pst archives (brew install libpst)
ENABLE_PST_IMPORT="false"
READPST_BIN="readpst"
UNZIP_BIN="unzip"

# Optional: read local Apple Mail cache (~/Library/Mail) after syncing in Mail.app
ENABLE_APPLE_MAIL_IMPORT="false"
# APPLE_MAIL_PATH="~/Library/Mail"
# APPLE_MAIL_LOOKBACK_DAYS="14"

# Optional: read calendar events synced into Calendar.app (EventKit export script)
ENABLE_APPLE_CALENDAR_IMPORT="false"
# APPLE_CALENDAR_NAMES="Calendar,Work"
# APPLE_CALENDAR_LOOKBACK_DAYS="14"
# APPLE_CALENDAR_LOOKAHEAD_DAYS="30"
# APPLE_CALENDAR_MAX_EVENTS="500"

# Background ingestion poll (Webex sync + Apple Mail/Calendar import)
# Auto-poll can also be enabled in Settings → Preferences → App configuration.
ENABLE_INGESTION_POLL="false"
# INGESTION_POLL_INTERVAL_MS="300000"
# INGESTION_POLL_SECRET=""  # Bearer token for cron: POST /api/integrations/poll

# Correlate Gong AI meeting summary emails with Webex meetings by title (default on)
# Also configurable in App configuration.
ENABLE_GONG_EMAIL_CORRELATION="true"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
