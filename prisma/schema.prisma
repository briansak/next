generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenancy ───────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  partner           Partner?
  members           TenantMember[]
  ingestionPolicies IngestionPolicy[]
  communications    Communication[]
  nextSteps         NextStep[]
  integrationTokens IntegrationToken[]
}

/// The external entity this team covers (e.g. a partner organization).
model Partner {
  id        String   @id @default(cuid())
  tenantId  String   @unique
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions          Session[]
  memberships       TenantMember[]
  assignedNextSteps NextStep[] @relation("AssignedTo")
  createdNextSteps  NextStep[] @relation("CreatedBy")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

enum MemberRole {
  ADMIN
  MEMBER
  VIEWER
}

model TenantMember {
  id        String     @id @default(cuid())
  tenantId  String
  userId    String
  role      MemberRole @default(MEMBER)
  createdAt DateTime   @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([tenantId])
}

// ─── Ingestion policies (allowlists) ─────────────────────────────────────────

enum IngestionSource {
  WEBEX
  EMAIL
}

enum PolicyStatus {
  DRAFT
  ACTIVE
  PAUSED
}

/// Whether a Webex space feeds day-job priorities or technology/GTM discussions.
enum WebexSpacePurpose {
  PRIORITIES
  TECHNOLOGY
}

/// Explicit allowlist configuration. Nothing is ingested without an ACTIVE policy.
model IngestionPolicy {
  id          String          @id @default(cuid())
  tenantId    String
  source      IngestionSource
  name        String
  status      PolicyStatus    @default(DRAFT)
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant           Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  webexAllowlists  WebexSpaceAllowlist[]
  emailAllowlists  EmailAllowlist[]

  @@index([tenantId, source, status])
}

/// Allowlisted Webex space. Only messages from these spaces are ingested.
model WebexSpaceAllowlist {
  id               String            @id @default(cuid())
  policyId         String
  spaceId          String
  spaceTitle       String?
  purpose          WebexSpacePurpose @default(PRIORITIES)
  /// Optional grouping label (e.g. "Networking", "Security") for Technologies view
  technologyLabel  String?
  technologySummaryCache Json?
  technologyFaqCache     Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @default(now()) @updatedAt

  policy IngestionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, spaceId])
}

/// Allowlisted email rule. Messages must match at least one active rule.
model EmailAllowlist {
  id        String   @id @default(cuid())
  policyId  String
  /// Match sender address exactly (e.g. partner-contact@acme.com)
  fromAddress String?
  /// Match sender domain (e.g. acme.com)
  fromDomain  String?
  /// Match subject prefix (e.g. "[Partner-ACME]")
  subjectPrefix String?
  createdAt DateTime @default(now())

  policy IngestionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
}

// ─── Integration credentials ─────────────────────────────────────────────────

enum IntegrationProvider {
  WEBEX
  MICROSOFT365
}

model IntegrationToken {
  id           String              @id @default(cuid())
  tenantId     String
  provider     IntegrationProvider
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, provider])
}

// ─── Communications ──────────────────────────────────────────────────────────

enum CommunicationSource {
  WEBEX
  WEBEX_MEETING
  EMAIL
  OUTLOOK_CALENDAR
}

enum Priority {
  CRITICAL  // 5
  HIGH      // 4
  MEDIUM    // 3
  LOW       // 2
  INFO      // 1
}

model Communication {
  id              String              @id @default(cuid())
  tenantId        String
  source          CommunicationSource
  /// External ID (Webex message ID, email Message-ID)
  externalId      String
  threadId        String?
  subject         String?
  body            String
  excerpt         String?
  authorName      String?
  authorEmail     String?
  receivedAt      DateTime
  priority        Priority            @default(INFO)
  priorityScore   Float               @default(0)
  priorityReasons String[]
  summary         String?
  tags            String[]
  /// Links back to the allowlist rule that permitted ingestion
  allowlistRef    String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nextSteps NextStep[]

  @@unique([tenantId, source, externalId])
  @@index([tenantId, priority, receivedAt])
  @@index([tenantId, threadId])
}

// ─── Next steps (collaborative action items) ─────────────────────────────────

enum NextStepStatus {
  OPEN
  IN_PROGRESS
  DONE
  DISMISSED
}

model NextStep {
  id              String         @id @default(cuid())
  tenantId        String
  communicationId String?
  title           String
  description     String?
  status          NextStepStatus @default(OPEN)
  dueAt           DateTime?
  priority        Priority       @default(MEDIUM)
  assigneeId      String?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  communication Communication? @relation(fields: [communicationId], references: [id], onDelete: SetNull)
  assignee      User?          @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy     User?          @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, status, priority])
}
