generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Local single-user app ───────────────────────────────────────────────────

model User {
  id                              String   @id @default(cuid())
  email                           String   @unique @default("local@next.local")
  name                            String?
  /// Legacy — local app no longer uses password login.
  passwordHash                    String?
  /// False until the first-launch setup questionnaire is finished.
  onboardingComplete              Boolean  @default(false)
  /// Partner organization this user covers (e.g. "Acme Corp")
  partnerName                     String?
  /// Non-sensitive app settings (Ollama URL, feature toggles, SLA, etc.)
  appConfig                       Json?
  /// Ordering for the dashboard "Your next steps" panel.
  nextStepOrder                   Json?
  /// Communication IDs hidden from the dashboard (survives ingest metadata refresh).
  dashboardHiddenCommunicationIds Json?
  /// When true, dashboard UI may call local Ollama for card summaries.
  allowOllamaSummaries            Boolean  @default(false)
  createdAt                       DateTime @default(now())
  updatedAt                       DateTime @updatedAt

  sessions          Session[]
  assignedNextSteps NextStep[] @relation("AssignedTo")
  createdNextSteps  NextStep[] @relation("CreatedBy")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// ─── Ingestion policies (allowlists) ─────────────────────────────────────────

enum IngestionSource {
  WEBEX
  EMAIL
}

enum PolicyStatus {
  DRAFT
  ACTIVE
  PAUSED
}

enum WebexSpacePurpose {
  PRIORITIES
  DEAL
  TECHNOLOGY
}

model IngestionPolicy {
  id          String          @id @default(cuid())
  source      IngestionSource @unique
  name        String
  status      PolicyStatus    @default(DRAFT)
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  webexAllowlists WebexSpaceAllowlist[]
  emailAllowlists EmailAllowlist[]
}

model WebexSpaceAllowlist {
  id                     String            @id @default(cuid())
  policyId               String
  spaceId                String
  spaceTitle             String?
  purpose                WebexSpacePurpose @default(PRIORITIES)
  technologyLabel        String?
  technologySummaryCache Json?
  technologyFaqCache     Json?
  dealLabel              String?
  dealSummaryCache       Json?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @default(now()) @updatedAt

  policy IngestionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@unique([policyId, spaceId])
}

model EmailAllowlist {
  id            String   @id @default(cuid())
  policyId      String
  fromAddress   String?
  fromDomain    String?
  subjectPrefix String?
  createdAt     DateTime @default(now())

  policy IngestionPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
}

// ─── Integration credentials ─────────────────────────────────────────────────

enum IntegrationProvider {
  WEBEX
  MICROSOFT365
}

model IntegrationToken {
  id           String              @id @default(cuid())
  provider     IntegrationProvider @unique
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  metadata     Json?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

/// Local app secrets encrypted at rest (OAuth client secrets, webhook keys, etc.)
model EncryptedSecrets {
  id                     String   @id @default("local")
  webexClientIdEnc       String?
  webexClientSecretEnc   String?
  webexWebhookSecretEnc  String?
  ingestionPollSecretEnc String?
  updatedAt              DateTime @updatedAt
  createdAt              DateTime @default(now())
}

// ─── Communications ──────────────────────────────────────────────────────────

enum CommunicationSource {
  WEBEX
  WEBEX_MEETING
  EMAIL
  OUTLOOK_CALENDAR
}

enum Priority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO
}

model Communication {
  id              String              @id @default(cuid())
  source          CommunicationSource
  externalId      String
  threadId        String?
  subject         String?
  body            String
  excerpt         String?
  authorName      String?
  authorEmail     String?
  receivedAt      DateTime
  priority        Priority            @default(INFO)
  priorityScore   Float               @default(0)
  priorityReasons String[]
  summary         String?
  tags            String[]
  allowlistRef    String?
  metadata        Json?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  nextSteps   NextStep[]
  commitments Commitment[]

  @@unique([source, externalId])
  @@index([priority, receivedAt])
  @@index([threadId])
}

enum NextStepStatus {
  OPEN
  IN_PROGRESS
  DONE
  DISMISSED
}

model NextStep {
  id              String         @id @default(cuid())
  communicationId String?
  title           String
  description     String?
  status          NextStepStatus @default(OPEN)
  dueAt           DateTime?
  priority        Priority       @default(MEDIUM)
  assigneeId      String?
  createdById     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  communication Communication? @relation(fields: [communicationId], references: [id], onDelete: SetNull)
  assignee      User?          @relation("AssignedTo", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy     User?          @relation("CreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([status, priority])
}

enum CommitmentOwner {
  ME
  PARTNER
  INTERNAL
  UNKNOWN
}

enum CommitmentStatus {
  OPEN
  FULFILLED
  DISMISSED
}

model Commitment {
  id              String           @id @default(cuid())
  communicationId String?
  title           String
  owner           CommitmentOwner  @default(UNKNOWN)
  ownerHint       String?
  dueAt           DateTime?
  status          CommitmentStatus @default(OPEN)
  source          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  communication Communication? @relation(fields: [communicationId], references: [id], onDelete: SetNull)

  @@unique([communicationId, title])
  @@index([status, owner])
}
